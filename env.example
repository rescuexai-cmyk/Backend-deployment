# Database
DATABASE_URL="postgresql://username:password@localhost:5432/raahi_db?schema=public"

# JWT - CRITICAL: Must be identical across ALL services (auth, user, driver, ride, notification, realtime, admin)
# If you change this, all users must log out and log in again. Min 32 chars recommended.
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"
REFRESH_TOKEN_EXPIRES_IN="30d"

# Server — Gateway uses port 3000 (avoids macOS port 5000 conflict). Other services use 5001–5008.
# Do not set a global PORT; each service has its own default.
GATEWAY_PORT=3000
NODE_ENV="development"

# CORS
FRONTEND_URL="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# Email (Nodemailer) — used for driver email verification OTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Raahi <noreply@raahi.app>"
SMTP_SECURE=false

# SMS (Twilio)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Apple Sign In (iOS bundle id; comma-separate additional Services IDs if needed)
APPLE_CLIENT_ID="com.rhi.raahi"

# Dev/Testing OTP Mode
# Set to "true" to allow static OTP "123456" for testing in production
# WARNING: Only enable temporarily for testing. Disable in production!
ALLOW_DEV_OTP="false"

# Truecaller
# Truecaller (Android SDK client id from https://developer.truecaller.com)
TRUECALLER_CLIENT_ID="your-truecaller-client-id"
TRUECALLER_API_KEY="your-truecaller-api-key"

# Payment Gateways
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# Razorpay Payout (Driver withdrawals)
RAZORPAY_ACCOUNT_NUMBER="your-razorpay-account-number"
PAYOUT_FEE_RATE=0
PAYOUT_FLAT_FEE=0

# Maps API
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Weather API (for dynamic pricing - OpenWeatherMap)
OPENWEATHERMAP_API_KEY=""

# Pricing Configuration
BASE_FARE=25
PER_KM_RATE=12
PER_MINUTE_RATE=2
SURGE_MULTIPLIER_MAX=3.0
PEAK_HOUR_MULTIPLIER=1.5

# File Upload (Local fallback)
MAX_FILE_SIZE=5242880
UPLOAD_PATH="./uploads"

# AWS S3 (Document storage)
# Leave empty to use local disk storage
AWS_S3_REGION="ap-south-1"
AWS_S3_BUCKET="raahi-documents"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_CLOUDFRONT_DOMAIN=""

# Internal Service Communication
INTERNAL_API_KEY="raahi-internal-service-key-change-in-production"

# DigiLocker Integration (Aadhaar verification)
DIGILOCKER_CLIENT_ID="your-digilocker-client-id"
DIGILOCKER_CLIENT_SECRET="your-digilocker-client-secret"

# Google Cloud Vision API (Document Auto-Verification)
# Option 1 (Recommended): API Key - simplest setup
GOOGLE_VISION_API_KEY=""
# Option 2: Path to service account JSON key file
GOOGLE_VISION_KEY_FILE=""
# Option 3: Inline JSON credentials (e.g. for containers/CI)
GOOGLE_VISION_CREDENTIALS=""
# Option 4: Set GOOGLE_APPLICATION_CREDENTIALS env var (standard GCP default)
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
# Confidence threshold for auto-approval (0.0 - 1.0)
VISION_CONFIDENCE_THRESHOLD=0.70

# Encryption (for sensitive data like tokens)
ENCRYPTION_KEY="your-32-char-encryption-key-here"

# Admin Configuration
# Promo dashboard login (email + password) — used at /promos
ADMIN_EMAIL="admin@raahi.com"
ADMIN_PASSWORD="change-me-to-a-strong-password"
# Optional: comma-separated app-user emails that can access other admin APIs via JWT
ADMIN_EMAILS="support@raahi.com"

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID="raahi-5f22e"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@raahi-5f22e.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Driver Penalties
PENALTY_STOP_RIDING_AMOUNT=10

