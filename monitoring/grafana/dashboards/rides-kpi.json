      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres" },
          "editorMode": "raw",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT TRIM(CONCAT(p.\"firstName\", ' ', COALESCE(p.\"lastName\", ''))) AS passenger, TRIM(CONCAT(dr.\"firstName\", ' ', COALESCE(dr.\"lastName\", ''))) AS driver, r.\"totalFare\", r.distance, r.\"completedAt\"\nFROM rides r\nJOIN users p ON r.\"passengerId\" = p.id\nLEFT JOIN drivers d ON r.\"driverId\" = d.id\nLEFT JOIN users dr ON d.\"userId\" = dr.id\nWHERE r.status = 'RIDE_COMPLETED'\nORDER BY r.\"completedAt\" DESC NULLS LAST\nLIMIT 100",
          "refId": "A"
        }
      ],
      "title": "Completed Rides – List",
      "type": "table"
    },
