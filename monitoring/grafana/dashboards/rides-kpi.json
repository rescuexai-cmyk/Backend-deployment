      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres" },
          "editorMode": "raw",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT TRIM(CONCAT(p.\"firstName\", ' ', COALESCE(p.\"lastName\", ''))) AS passenger, r.status, r.\"pickupAddress\", r.\"createdAt\"\nFROM rides r\nJOIN users p ON r.\"passengerId\" = p.id\nWHERE r.status IN ('PENDING', 'CONFIRMED', 'DRIVER_ASSIGNED', 'DRIVER_ARRIVED', 'RIDE_STARTED')\nORDER BY r.\"createdAt\" DESC\nLIMIT 100",
          "refId": "A"
        }
      ],
      "title": "In-Progress Rides – List",
