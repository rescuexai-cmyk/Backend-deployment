          "rawQuery": true,
          "rawSql": "SELECT TRIM(CONCAT(u.\"firstName\", ' ', COALESCE(u.\"lastName\", ''))) AS name, u.phone, d.\"vehicleNumber\", d.rating, d.\"joinedAt\"\nFROM drivers d\nJOIN users u ON d.\"userId\" = u.id\nWHERE d.\"isVerified\" = true\nORDER BY d.\"joinedAt\" DESC\nLIMIT 100",
