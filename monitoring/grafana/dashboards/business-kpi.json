          "datasource": { "type": "postgres", "uid": "postgres" },
          "editorMode": "raw",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT TRIM(CONCAT(u.\"firstName\", ' ', COALESCE(u.\"lastName\", ''))) AS name, u.phone, u.email, d.rating, d.\"vehicleType\", d.\"lastActiveAt\"\nFROM drivers d\nJOIN users u ON d.\"userId\" = u.id\nWHERE d.\"isActive\" = true\nORDER BY d.\"lastActiveAt\" DESC NULLS LAST\nLIMIT 100",
