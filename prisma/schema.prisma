// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  phone             String    @unique
  firstName         String
  lastName          String?
  profileImage      String?
  isVerified        Boolean   @default(false)
  isActive          Boolean   @default(true)
  /// Email ownership confirmed via OTP (separate from phone `isVerified`).
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  emailVerificationOtp           String?
  emailVerificationOtpExpiresAt  DateTime?
  emailVerificationSentAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?
  deletedAt         DateTime? // Set when user requests account deletion (soft-delete)
  deletionReason    String?   // Optional reason captured from the user at deletion time
  
  // Firebase Auth integration
  firebaseUid       String?   @unique  // Firebase user UID for phone auth
  
  // Push notification tokens (FCM for both iOS and Android)
  fcmToken          String?   // Firebase Cloud Messaging token for push notifications
  fcmTokenUpdatedAt DateTime? // When the token was last updated
  devicePlatform    String?   // 'ios', 'android', or 'web'
  deviceId          String?   // Unique device identifier for multi-device support
  
  // Last known location (updated when user requests a ride or updates location)
  lastLatitude      Float?
  lastLongitude     Float?
  lastLocationAt    DateTime?
  
  // Relations
  rides             Ride[]    @relation("PassengerRides")
  driverProfile     Driver?
  refreshTokens     RefreshToken[]
  notifications     Notification[]
  savedPlaces       SavedPlace[]
  supportTickets    SupportTicket[]
  rescueRequests    RescueRequest[]
  
  @@index([lastLatitude, lastLongitude])
  @@index([firebaseUid])
  @@index([fcmToken])
  @@map("users")
}

model SavedPlace {
  id          String   @id @default(cuid())
  userId      String
  name        String   // e.g. "Home", "Work", "Gym"
  address     String
  latitude    Float
  longitude   Float
  placeType   String?  // home, work, other
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("saved_places")
}

model SupportTicket {
  id          String              @id @default(cuid())
  userId      String?             // For passenger support
  driverId    String?             // For driver support
  issueType   String
  description String   @db.VarChar(2000)  // Limit description length
  priority    SupportPriority     @default(MEDIUM)
  status      SupportTicketStatus @default(OPEN)
  response    String?  @db.VarChar(2000)  // Limit response length
  respondedAt DateTime?
  respondedBy String?             // Admin user ID
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  driver      Driver?             @relation(fields: [driverId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@map("support_tickets")
}

model Driver {
  id                String    @id @default(cuid())
  userId            String    @unique
  licenseNumber     String?   @unique
  licenseExpiry     DateTime?
  vehicleNumber     String?   @unique
  vehicleModel      String?
  vehicleColor      String?
  vehicleYear       Int?
  isVerified        Boolean   @default(false)
  isActive          Boolean   @default(true)
  isOnline          Boolean   @default(false)
  currentLatitude   Float?
  currentLongitude  Float?
  h3Index           String?   // H3 hexagonal geospatial index for efficient matching
  rating            Float     @default(0.0)
  ratingCount       Int       @default(0)  // Actual count of ratings received (for correct average)
  totalRides        Int       @default(0)
  totalEarnings     Float     @default(0.0)
  totalOnlineSeconds Int      @default(0)  // Track total online time for hours_online
  joinedAt          DateTime  @default(now())
  lastActiveAt      DateTime?
  lastOnlineAt      DateTime? // When driver last went online (for session tracking)
  
  // Onboarding fields
  onboardingStatus  OnboardingStatus @default(EMAIL_COLLECTION)
  preferredLanguage String?
  vehicleType       String?
  serviceTypes      String[]  // Array of service types: ["bike_rescue", "raahi_driver"]
  documentsSubmittedAt DateTime?
  documentsVerifiedAt  DateTime?
  verificationNotes    String?
  referralCode      String?   // Referral code used during signup
  
  // KYC/Verification fields
  aadhaarNumber     String?   @unique  // 12-digit Aadhaar number (encrypted in production)
  aadhaarVerified   Boolean   @default(false)
  aadhaarVerifiedAt DateTime?
  panNumber         String?   @unique  // 10-character PAN (e.g., ABCDE1234F)
  panVerified       Boolean   @default(false)
  panVerifiedAt     DateTime?
  digilockerLinked  Boolean   @default(false)  // Whether DigiLocker is linked
  digilockerToken   String?   // DigiLocker access token (encrypted)
  
  // Account management (admin actions)
  accountStatus       DriverAccountStatus @default(ACTIVE)
  accountStatusReason String?             // Reason for suspend/terminate
  accountStatusAt     DateTime?           // When status was last changed
  accountStatusBy     String?             // Admin who changed the status
  hasDriverPass       Boolean   @default(false) // Admin-toggled driver pass
  
  // Settings
  notificationsEnabled Boolean @default(true)
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rides             Ride[]    @relation("DriverRides")
  rescueRides       Ride[]    @relation("Driver2Rides")  // Rides where this driver is driver2 (rescue)
  documents         DriverDocument[]
  earnings          DriverEarning[]
  penalties         DriverPenalty[]
  supportTickets    SupportTicket[]
  payoutAccounts    DriverPayoutAccount[]
  payouts           DriverPayout[]
  wallet            DriverWallet?
  rescueDriver1     RescueRequest[]  @relation("RescueDriver1")
  rescueDriver2     RescueRequest[]  @relation("RescueDriver2")
  
  @@index([isOnline, isActive])
  @@index([currentLatitude, currentLongitude])
  @@index([h3Index])  // H3 index for geospatial queries - critical for performance
  @@index([onboardingStatus])
  @@index([accountStatus])
  @@map("drivers")
}

model DriverPenalty {
  id         String        @id @default(cuid())
  driverId   String
  amount     Float         // in INR, e.g. 10 for "Stop Riding"
  reason     String        // e.g. "STOP_RIDING"
  status     PenaltyStatus @default(PENDING)
  issuedBy   String?       // "SYSTEM" or "ADMIN" — who created the penalty
  createdAt  DateTime      @default(now())
  paidAt     DateTime?
  
  driver     Driver        @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  @@index([driverId])
  @@index([status])
  @@map("driver_penalties")
}

model DriverDocument {
  id                String    @id @default(cuid())
  driverId          String
  documentType      DocumentType
  documentUrl       String
  documentName      String?
  documentSize      Int?
  isVerified        Boolean   @default(false)
  verifiedAt        DateTime?
  verifiedBy        String?   // Admin user ID who verified, or "AI_VISION" for auto-verification
  rejectionReason   String?
  uploadedAt        DateTime  @default(now())
  
  // AI Vision verification fields
  aiVerified           Boolean   @default(false)
  aiConfidence         Float?
  aiExtractedData      Json?
  aiVerifiedAt         DateTime?
  aiMismatchReason     String?
  verificationStatus   String    @default("pending") // pending, processing, verified, flagged, failed
  
  // Relations
  driver            Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  @@index([driverId])
  @@index([documentType])
  @@index([verificationStatus])
  @@map("driver_documents")
}

model DriverEarning {
  id                String    @id @default(cuid())
  driverId          String
  rideId            String?   @unique
  amount            Float     // Gross fare
  commission        Float     // Platform fee deducted
  commissionRate    Float     @default(0.20) // Platform fee rate (e.g. 0.20 = 20%)
  netAmount         Float     // amount - commission
  baseFare          Float     @default(0)    // Breakdown: base fare portion
  distanceFare      Float     @default(0)    // Breakdown: distance fare portion
  timeFare          Float     @default(0)    // Breakdown: time fare portion
  surgeFare         Float     @default(0)    // Breakdown: surge bonus portion
  date              DateTime  @default(now())
  
  // Relations
  driver            Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  @@index([driverId])
  @@index([date])
  @@index([driverId, date])
  @@map("driver_earnings")
}

model Ride {
  id                String    @id @default(cuid())
  passengerId       String
  driverId          String?
  pickupLatitude    Float
  pickupLongitude   Float
  dropLatitude      Float
  dropLongitude     Float
  pickupAddress     String
  dropAddress       String
  distance          Float     // in kilometers
  duration          Int       // in minutes
  baseFare          Float
  distanceFare      Float
  timeFare          Float
  surgeMultiplier   Float     @default(1.0)
  surgeFare         Float     @default(0.0)  // Surge bonus amount
  totalFare         Float
  status            RideStatus @default(PENDING)
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus @default(PENDING)
  vehicleType       String?   // Requested vehicle type (bike_rescue, auto, cab_mini, cab_xl, cab_premium)
  rideOtp           String?   // 4-digit OTP for ride verification (driver must enter to start ride)
  
  // Rescue Service fields
  rideType          String    @default("NORMAL")  // "NORMAL" or "RESCUE"
  rescueMultiDriver Boolean   @default(false)     // true if rescue needs 2 drivers
  rescueStage       Int       @default(0)         // 0-5 for multi-driver rescue stages
  driver2Id         String?                       // Second driver ID for multi-driver rescue
  
  scheduledAt       DateTime?
  driverAssignedAt  DateTime? // When driver was assigned to ride
  driverArrivedAt   DateTime? // When driver tapped "I've arrived" (for waiting time calc)
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelledBy       String?   // 'passenger' or 'driver'
  cancellationReason String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Post-ride fare adjustments (driver input at completion)
  tolls             Float     @default(0)   // Toll charges (₹)
  waitingMinutes    Int       @default(0)   // Time driver waited at pickup (mins)
  parkingFees       Float     @default(0)   // Parking charges (₹)
  extraStopsCount   Int       @default(0)   // Additional stops beyond origin
  discountPercent   Float     @default(0)   // Post-ride manual/driver discount (0–100)

  // Promo/coupon applied at booking time
  promoCode         String?                 // e.g. "FIRST50"
  promoId           String?                 // FK-ish reference to promos.id (loose, no relation)
  discountAmount    Float     @default(0)   // ₹ discount already reflected in totalFare

  // Immutable quote snapshot from pricing-service (line items + rates).
  // Frontend must display this as-is — no local fare math.
  fareBreakdown     Json?
  
  // Rating fields (per-ride rating)
  passengerRating   Int?      // 1-5 rating given by passenger to driver
  passengerFeedback String?   @db.VarChar(500)  // Optional feedback from passenger
  ratedByPassengerAt DateTime?
  driverRating      Int?      // 1-5 rating given by driver to passenger (future use)
  driverFeedback    String?   @db.VarChar(500)  // Optional feedback from driver
  ratedByDriverAt   DateTime?
  
  // Relations
  passenger         User      @relation("PassengerRides", fields: [passengerId], references: [id])
  driver            Driver?   @relation("DriverRides", fields: [driverId], references: [id])
  driver2           Driver?   @relation("Driver2Rides", fields: [driver2Id], references: [id])
  tracking          RideTracking[]
  messages          RideMessage[]
  chatParticipants  RideChatParticipant[]
  shareTokens       RideShareToken[]
  stops             RideStop[]
  
  @@index([passengerId])
  @@index([driverId])
  @@index([driver2Id])
  @@index([status])
  @@index([createdAt])
  @@index([status, driverId])
  @@index([passengerId, status])
  @@index([rideType])
  @@map("rides")
}

model RideStop {
  id        String   @id @default(cuid())
  rideId    String
  latitude  Float
  longitude Float
  address   String
  sequence  Int      // Order of stops (0, 1, 2, ...)
  createdAt DateTime @default(now())

  ride      Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@index([rideId])
  @@map("ride_stops")
}

model RideShareToken {
  id        String   @id @default(cuid())
  rideId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  ride      Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)
  
  @@index([rideId])
  @@index([expiresAt])
  @@map("ride_share_tokens")
}

model RideTracking {
  id                String    @id @default(cuid())
  rideId            String
  latitude          Float
  longitude         Float
  heading           Float?
  speed             Float?
  timestamp         DateTime  @default(now())
  
  // Relations
  ride              Ride      @relation(fields: [rideId], references: [id], onDelete: Cascade)
  
  @@index([rideId])
  @@index([timestamp])
  @@map("ride_tracking")
}

model RideMessage {
  id                String    @id @default(cuid())
  rideId            String
  senderId          String
  clientMessageId   String?
  message           String    @db.VarChar(1000)
  timestamp         DateTime  @default(now())
  
  // Relations
  ride              Ride      @relation(fields: [rideId], references: [id], onDelete: Cascade)
  
  @@index([rideId])
  @@index([timestamp])
  @@unique([rideId, senderId, clientMessageId])
  @@map("ride_messages")
}

model RideChatParticipant {
  id          String   @id @default(cuid())
  rideId      String
  userId      String
  lastReadAt  DateTime?
  unreadCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  ride        Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@unique([rideId, userId])
  @@index([rideId])
  @@index([userId])
  @@index([rideId, userId, lastReadAt])
  @@map("ride_chat_participants")
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  token             String    @unique
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Notification {
  id                String    @id @default(cuid())
  userId            String
  title             String
  message           String
  type              NotificationType
  isRead            Boolean   @default(false)
  data              Json?
  createdAt         DateTime  @default(now())
  
  // Geo-targeting fields (for location-based notifications)
  // If these are set, notification was sent based on geographic targeting
  targetLatitude    Float?    // Center latitude of target area (null for user-specific)
  targetLongitude   Float?    // Center longitude of target area (null for user-specific)
  targetRadius      Float?    // Radius in kilometers (null for user-specific)
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@index([targetLatitude, targetLongitude])
  @@map("notifications")
}

model PricingRule {
  id                String    @id @default(cuid())
  name              String
  baseFare          Float
  perKmRate         Float
  perMinuteRate     Float
  surgeMultiplier   Float     @default(1.0)
  peakHourMultiplier Float    @default(1.0)
  isActive          Boolean   @default(true)
  validFrom         DateTime
  validTo           DateTime?
  createdAt         DateTime  @default(now())
  
  @@index([isActive])
  @@index([validFrom, validTo])
  @@map("pricing_rules")
}

model SurgeArea {
  id                String    @id @default(cuid())
  name              String
  centerLatitude    Float
  centerLongitude   Float
  radius            Float     // in kilometers
  multiplier        Float
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  
  @@index([isActive])
  @@index([centerLatitude, centerLongitude])
  @@map("surge_areas")
}

model TollPlaza {
  id          String   @id @default(cuid())
  name        String
  latitude    Float
  longitude   Float
  amount      Float    // Toll amount in ₹
  highway     String?  // e.g. "NH-48", "Delhi-Mumbai"
  city        String?
  state       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  @@index([latitude, longitude])
  @@index([isActive])
  @@map("toll_plazas")
}

// ─────────────────────────────────────────────────────────────
// Per-city/region pricing
// ─────────────────────────────────────────────────────────────

model CityPricing {
  id            String   @id @default(cuid())
  city          String   // "delhi", "gurgaon", "noida", "faridabad"
  vehicleType   String   // "cab_mini", "auto", "cab_xl", "bike_rescue", "cab_premium", "personal_driver"
  startingFee   Float
  ratePerKm     Float
  ratePerMin    Float
  minimumFare   Float
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([city, vehicleType])
  @@index([city])
  @@index([isActive])
  @@map("city_pricing")
}

// ─────────────────────────────────────────────────────────────
// Marketplace pricing policy v2
// ─────────────────────────────────────────────────────────────

model PricingCityPolicy {
  id                String   @id @default(cuid())
  cityCode          String   @unique
  marketplaceMode   String   @default("scale") // launch | scale
  launchSubsidyPct  Float    @default(0.25)
  launchSubsidyCap  Float    @default(80)
  burnCap           Float    @default(0.22)
  contributionFloor Float    @default(-40)
  etaTargetMin      Float    @default(8)
  supplyThreshold   Float    @default(0.9)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isActive])
  @@index([marketplaceMode])
  @@map("pricing_city_policy")
}

model PricingBurnMetric {
  id         String   @id @default(cuid())
  cityCode   String
  date       DateTime
  gmv        Float    @default(0)
  subsidy    Float    @default(0)
  incentives Float    @default(0)
  burnRate   Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([cityCode, date])
  @@index([cityCode, date])
  @@map("pricing_burn_metrics")
}

model PricingZoneHealth {
  id          String   @id @default(cuid())
  zoneId      String
  cityCode    String
  fulfillment Float    @default(0)
  etaP90      Float    @default(0)
  acceptRate  Float    @default(0)
  healthScore Float    @default(0)
  observedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([zoneId, cityCode])
  @@index([cityCode, healthScore])
  @@index([observedAt])
  @@map("pricing_zone_health")
}

// ─────────────────────────────────────────────────────────────
// Promotions and discounts
// ─────────────────────────────────────────────────────────────

model Promo {
  id              String      @id @default(cuid())
  code            String      @unique
  type            PromoType   // PERCENT, FLAT, CASHBACK
  value           Float       // e.g. 10 for 10% or ₹50
  maxDiscount     Float?      // cap for percent type
  minFare         Float?      // minimum fare to apply
  usageLimit      Int?        // total uses allowed (null = unlimited)
  perUserLimit    Int         @default(1)
  validFrom       DateTime
  validTo         DateTime?
  vehicleTypes    String[]    // [] = all
  cities          String[]    // [] = all
  isFirstRideOnly Boolean     @default(false)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  usages          PromoUsage[]
  
  @@index([code])
  @@index([isActive])
  @@index([validFrom, validTo])
  @@map("promos")
}

model PromoUsage {
  id        String   @id @default(cuid())
  promoId   String
  userId    String
  rideId    String?
  usedAt    DateTime @default(now())
  
  promo     Promo    @relation(fields: [promoId], references: [id], onDelete: Cascade)
  
  @@unique([promoId, userId, rideId])
  @@index([promoId])
  @@index([userId])
  @@map("promo_usages")
}

// ─────────────────────────────────────────────────────────────
// Marketing banners (home screen carousels, etc.)
// ─────────────────────────────────────────────────────────────

model Banner {
  id        String          @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?         // deeplink or external URL when tapped
  placement BannerPlacement @default(HOME)
  sortOrder Int             @default(0) // lower = shown first
  validFrom DateTime        @default(now())
  validTo   DateTime?
  cities    String[]        // [] = all cities
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([placement, isActive])
  @@index([sortOrder])
  @@index([validFrom, validTo])
  @@map("banners")
}

// ─────────────────────────────────────────────────────────────
// Cancellation policy
// ─────────────────────────────────────────────────────────────

model CancellationPolicy {
  id                    String   @id @default(cuid())
  vehicleType           String   // "cab_mini", "auto", etc.
  city                  String?  // null = all cities
  freeWindowMinutes     Int      @default(2)   // Free cancellation window after assignment
  freeWaitingMinutes    Int      @default(3)   // Free waiting after driver arrived
  waitingFeePerMin      Float    // Fee per minute after free waiting
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  
  @@unique([vehicleType, city])
  @@index([vehicleType])
  @@index([isActive])
  @@map("cancellation_policies")
}

// ─────────────────────────────────────────────────────────────
// Driver incentives (future)
// ─────────────────────────────────────────────────────────────

model DriverIncentive {
  id            String        @id @default(cuid())
  name          String        // "Complete 10 rides today"
  type          IncentiveType // RIDES_COUNT, EARNINGS_TARGET, ONLINE_HOURS, PEAK_RIDES
  targetValue   Float         // e.g. 10 rides, ₹2000 earnings
  bonusAmount   Float         // ₹100 bonus
  validFrom     DateTime
  validTo       DateTime
  cities        String[]      // [] = all
  vehicleTypes  String[]      // [] = all
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  
  progress      DriverIncentiveProgress[]
  
  @@index([isActive])
  @@index([validFrom, validTo])
  @@map("driver_incentives")
}

model DriverIncentiveProgress {
  id           String    @id @default(cuid())
  driverId     String
  incentiveId  String
  progress     Float     @default(0)
  achieved     Boolean   @default(false)
  achievedAt   DateTime?
  paidOut      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  incentive    DriverIncentive @relation(fields: [incentiveId], references: [id], onDelete: Cascade)
  
  @@unique([driverId, incentiveId])
  @@index([driverId])
  @@index([incentiveId])
  @@map("driver_incentive_progress")
}

// Enums
enum PromoType {
  PERCENT
  FLAT
  CASHBACK
}

enum BannerPlacement {
  HOME
  RIDES
  PROFILE
}

enum IncentiveType {
  RIDES_COUNT
  EARNINGS_TARGET
  ONLINE_HOURS
  PEAK_RIDES
}

enum DocumentType {
  LICENSE
  RC
  INSURANCE
  PUC
  PROFILE_PHOTO
  PAN_CARD
  AADHAAR_CARD
}

enum OnboardingStatus {
  EMAIL_COLLECTION
  LANGUAGE_SELECTION
  EARNING_SETUP
  VEHICLE_SELECTION
  LICENSE_UPLOAD
  PROFILE_PHOTO
  PHOTO_CONFIRMATION
  DOCUMENT_UPLOAD
  DOCUMENT_VERIFICATION
  COMPLETED
  REJECTED
}

enum RideStatus {
  SCHEDULED
  PENDING
  CONFIRMED
  DRIVER_ASSIGNED
  DRIVER_ARRIVED
  RIDE_STARTED
  RIDE_COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  WALLET
  SCAN_TO_PAY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PenaltyStatus {
  PENDING
  PAID
}

enum DriverAccountStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum NotificationType {
  RIDE_UPDATE
  PAYMENT
  PROMOTION
  SYSTEM
  SUPPORT
}

enum SupportPriority {
  LOW
  MEDIUM
  HIGH
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// Platform configuration model for dynamic fee rates
model PlatformConfig {
  id                 String   @id @default(cuid())
  key                String   @unique
  value              String   // JSON or string value
  description        String?
  updatedAt          DateTime @updatedAt
  
  @@map("platform_config")
}

// ═══════════════════════════════════════════════════════════════════════════════
// DRIVER PAYOUT SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

// Driver Bank Account / UPI for receiving payouts
model DriverPayoutAccount {
  id              String            @id @default(cuid())
  driverId        String
  accountType     PayoutAccountType
  
  // Bank Account Details
  bankName        String?
  accountNumber   String?           // Last 4 digits stored, full number encrypted separately
  accountNumberEncrypted String?    // Full account number (encrypted)
  ifscCode        String?
  accountHolderName String?
  
  // UPI Details
  upiId           String?           // e.g., driver@upi, driver@paytm
  
  // Razorpay Integration
  razorpayContactId    String?      // Razorpay Contact ID
  razorpayFundAccountId String?     // Razorpay Fund Account ID
  
  // Verification
  isVerified      Boolean           @default(false)
  verifiedAt      DateTime?
  verificationMethod String?        // penny_drop, upi_verify, manual
  isPrimary       Boolean           @default(false)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  driver          Driver            @relation(fields: [driverId], references: [id], onDelete: Cascade)
  payouts         DriverPayout[]
  
  @@index([driverId])
  @@index([isPrimary])
  @@map("driver_payout_accounts")
}

// Driver Wallet for tracking available balance
model DriverWallet {
  id              String    @id @default(cuid())
  driverId        String    @unique
  
  // Balance tracking
  availableBalance Float    @default(0)   // Ready for withdrawal
  pendingBalance   Float    @default(0)   // Earnings being processed/settled
  holdBalance      Float    @default(0)   // Held for penalties or disputes
  totalWithdrawn   Float    @default(0)   // Lifetime withdrawals
  totalEarned      Float    @default(0)   // Lifetime earnings (for reference)
  
  // Settlement tracking
  lastSettlementAt DateTime?
  lastPayoutAt     DateTime?
  
  // Minimum withdrawal threshold
  minimumWithdrawal Float   @default(100) // ₹100 minimum
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  driver          Driver    @relation(fields: [driverId], references: [id], onDelete: Cascade)
  
  @@map("driver_wallets")
}

// Payout/Withdrawal Requests
model DriverPayout {
  id              String        @id @default(cuid())
  driverId        String
  payoutAccountId String?
  
  // Amount details
  amount          Float         // Requested amount
  fee             Float         @default(0)  // Processing fee (if any)
  netAmount       Float         // amount - fee (actual transfer)
  
  // Status tracking
  status          PayoutStatus  @default(PENDING)
  payoutMethod    PayoutAccountType
  
  // Payment gateway details
  razorpayPayoutId String?      // Razorpay Payout ID
  transactionId    String?      // UTR/Transaction reference
  failureReason    String?
  failureCode      String?
  
  // Timing
  requestedAt     DateTime      @default(now())
  processedAt     DateTime?     // When processing started
  completedAt     DateTime?     // When money was transferred
  
  // Metadata
  remarks         String?       // Admin notes
  isAutoSettlement Boolean      @default(false) // True if triggered by auto-settlement
  
  driver          Driver        @relation(fields: [driverId], references: [id], onDelete: Cascade)
  payoutAccount   DriverPayoutAccount? @relation(fields: [payoutAccountId], references: [id], onDelete: SetNull)
  
  @@index([driverId])
  @@index([status])
  @@index([requestedAt])
  @@index([isAutoSettlement])
  @@map("driver_payouts")
}

// Wallet Transaction Log (for audit trail)
model WalletTransaction {
  id              String              @id @default(cuid())
  driverId        String
  
  // Transaction details
  type            WalletTransactionType
  amount          Float               // Positive for credit, negative for debit
  balanceBefore   Float
  balanceAfter    Float
  
  // Reference
  referenceType   String?             // ride, payout, penalty, adjustment, settlement
  referenceId     String?             // ID of the related record
  
  description     String?
  createdAt       DateTime            @default(now())
  
  @@index([driverId])
  @@index([type])
  @@index([createdAt])
  @@index([referenceType, referenceId])
  @@map("wallet_transactions")
}

// Enums for Payout System
enum PayoutAccountType {
  BANK_ACCOUNT
  UPI
}

enum PayoutStatus {
  PENDING       // Withdrawal requested
  PROCESSING    // Being processed by payment gateway
  COMPLETED     // Successfully transferred
  FAILED        // Transfer failed
  CANCELLED     // Cancelled by driver or admin
  REVERSED      // Money returned due to issue
}

enum WalletTransactionType {
  RIDE_EARNING      // Credit from completed ride
  WITHDRAWAL        // Debit for payout
  PENALTY           // Debit for penalty
  PENALTY_REVERSAL  // Credit for reversed penalty
  ADJUSTMENT        // Manual adjustment by admin
  SETTLEMENT        // Auto-settlement credit
  HOLD              // Amount put on hold
  RELEASE           // Amount released from hold
  REFUND            // Refund credited
}

// ═══════════════════════════════════════════════════════════════════════════════
// DRIVER SUBSCRIPTION (DAILY PLATFORM FEE)
// ═══════════════════════════════════════════════════════════════════════════════

model DriverSubscription {
  id              String                    @id @default(cuid())
  driverId        String                    @unique
  
  // Subscription status
  lastPaidAt      DateTime?                 // When the driver last paid
  validTill       DateTime?                 // Subscription valid until
  isActive        Boolean                   @default(false)
  
  // Payment tracking
  totalPayments   Int                       @default(0)
  totalAmount     Float                     @default(0)
  
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  
  // Relations
  payments        DriverSubscriptionPayment[]
  
  @@index([driverId])
  @@index([validTill])
  @@index([isActive])
  @@map("driver_subscriptions")
}

model DriverSubscriptionPayment {
  id              String                    @id @default(cuid())
  subscriptionId  String
  driverId        String
  
  // Payment details
  amount          Float                     // ₹39
  paymentMethod   String                    @default("UPI") // UPI, WALLET, etc.
  transactionId   String?                   // UPI transaction ID
  
  // Status
  status          SubscriptionPaymentStatus @default(PENDING)
  
  // Validity period this payment grants
  validFrom       DateTime
  validTill       DateTime
  
  createdAt       DateTime                  @default(now())
  verifiedAt      DateTime?
  
  subscription    DriverSubscription        @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  @@index([subscriptionId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@map("driver_subscription_payments")
}

enum SubscriptionPaymentStatus {
  PENDING
  VERIFIED
  FAILED
  REFUNDED
}

// ═══════════════════════════════════════════════════════════════════════════════
// RESCUE SERVICE
// ═══════════════════════════════════════════════════════════════════════════════

model RescueRequest {
  id                    String              @id @default(cuid())
  userId                String              // The user requesting rescue
  
  // Screen ① — Rescue Service Type
  rescueServiceType     RescueServiceType   @default(PASSENGER_VEHICLE_RESCUE)
  
  // Screen ② — What's Happening (reason for rescue)
  reason                String?             // "stuck_in_traffic", "feeling_unsafe", "driver_unavailable", etc.
  reasonDetails         String?             // Free-text when user selects "Other (Tell us)"
  
  // Screen ③ — Location & vehicle presence
  pickupAddress         String
  pickupLatitude        Float
  pickupLongitude       Float
  dropAddress           String
  dropLatitude          Float
  dropLongitude         Float
  isVehicleWithUser     Boolean             @default(true) // "Is your vehicle with you?" Yes/No
  
  // Screen ④ — Vehicle Details
  hasVehicle                Boolean         @default(false)
  vehicleType               String?         // "TWO_WHEELER" or "FOUR_WHEELER" (Bike, Scooter, Hatchback, Sedan, SUV)
  vehicleSubType            String?         // Granular: "BIKE", "SCOOTER", "HATCHBACK", "SEDAN", "SUV"
  vehicleRegistrationNumber String?         // "MP04 XX 1234"
  vehicleRegistrationState  String?         // "MP" — state code for registration
  vehicleTransmission       String?         // "MANUAL" or "AUTOMATIC"
  vehicleIssues             String[]        // ["flat_tyre", "overheating", "damage", "engine_failure", "battery_dead"]
  
  // Screen ⑤ — Vehicle drop location
  vehicleDropAddress    String?             // Where to drop the vehicle
  vehicleDropLatitude   Float?
  vehicleDropLongitude  Float?
  vehicleDropSameAsDrop Boolean             @default(false)
  
  // Driver Assignments
  driver1Id             String?             // Primary driver (drops the user)
  driver2Id             String?             // Secondary driver (drops the vehicle)
  
  // Linked Rides (created in ride-service)
  userRideId            String?             @unique  // Ride for user drop
  vehicleRideId         String?             @unique  // Ride for vehicle drop
  
  // Rescue OTP (shared with both drivers)
  rescueOtp             String?             // 4-digit OTP
  
  // Status & Stage Tracking
  status                RescueStatus        @default(PENDING)
  rescueStage           Int                 @default(0)
  // Stage 0: PENDING — Waiting for drivers
  // Stage 1: DRIVER1_ACCEPTED — First driver accepted, waiting for second
  // Stage 2: BOTH_ACCEPTED — Both drivers accepted (or single driver if no vehicle)
  // Stage 3: DRIVERS_EN_ROUTE — Driver1 picked up Driver2, heading to user
  // Stage 4: DRIVERS_ARRIVED — Drivers arrived at user pickup
  // Stage 5: IN_PROGRESS — OTP verified, rides started
  // Stage 6: COMPLETED — All rides completed
  
  paymentMethod         String              @default("CASH")  // CASH, UPI, etc.
  
  // Screen ⑥ — Fare Estimate (stored at creation for reference)
  estimatedPassengerFare  Float?            // Passenger transport estimate
  estimatedVehicleFare    Float?            // Vehicle delivery estimate
  estimatedPlatformFee    Float?            // Platform fee
  estimatedInsuranceFee   Float?            // Insurance fee
  estimatedTotalFare      Float?            // Grand total estimate
  
  // Screen ⑨ — SOS
  sosTriggered          Boolean             @default(false)
  sosTriggeredAt        DateTime?
  sosResolvedAt         DateTime?
  sosNotes              String?
  
  // Screen ⑩ — Vehicle Delivery Verification
  vehicleDeliveryStatus     String?         // "PENDING", "ACCEPTED", "ISSUE_REPORTED"
  vehicleConditionPhotos    String[]        // URLs of delivery condition photos
  vehicleDeliveryNotes      String?         // User notes on delivery acceptance
  vehicleDeliveryAcceptedAt DateTime?
  vehicleDeliveryIssue      String?         // Issue description if user reports a problem
  
  // Timestamps
  driver1AcceptedAt     DateTime?
  driver2AcceptedAt     DateTime?
  driversEnRouteAt      DateTime?
  driversArrivedAt      DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancelledBy           String?
  cancellationReason    String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  // Relations
  user                  User                @relation(fields: [userId], references: [id])
  driver1               Driver?             @relation("RescueDriver1", fields: [driver1Id], references: [id])
  driver2               Driver?             @relation("RescueDriver2", fields: [driver2Id], references: [id])
  timelineEvents        RescueTimelineEvent[]
  ratings               RescueRating[]
  
  @@index([userId])
  @@index([status])
  @@index([driver1Id])
  @@index([driver2Id])
  @@index([createdAt])
  @@index([userId, status])
  @@map("rescue_requests")
}

// ─── Rescue Timeline Events (Screen ⑨ Timeline Tab) ──────────────────────────
// Immutable log of every significant event during a rescue journey.
// Powers the Timeline tab in the Journey Hub.

model RescueTimelineEvent {
  id          String   @id @default(cuid())
  rescueId    String
  event       String   // Machine-readable: "REQUEST_CREATED", "DRIVER1_ACCEPTED", "DRIVERS_EN_ROUTE", etc.
  title       String   // Human-readable: "Rescue request received", "Bike rider on the way"
  description String?  // Optional detail text
  actor       String?  // "system", "driver", "user", or specific driverId/userId
  metadata    Json?    // Flexible additional data (e.g., driver name, location snapshot)
  createdAt   DateTime @default(now())

  rescue      RescueRequest @relation(fields: [rescueId], references: [id], onDelete: Cascade)

  @@index([rescueId])
  @@index([rescueId, createdAt])
  @@map("rescue_timeline_events")
}

// ─── Rescue Ratings (Screen ⑪ Rating & Complete) ─────────────────────────────
// Multi-party rating: user rates Rider Driver, Vehicle Driver, and Support separately.

model RescueRating {
  id            String   @id @default(cuid())
  rescueId      String
  userId        String   // The user giving the rating
  targetType    String   // "RIDER_DRIVER", "VEHICLE_DRIVER", "SUPPORT"
  targetId      String?  // Driver ID for driver ratings, null for SUPPORT
  rating        Int      // 1-5 stars
  feedback      String?  @db.VarChar(500) // Optional text feedback
  problemSolved Boolean? // "Was your problem solved?" (Screen ⑪)
  createdAt     DateTime @default(now())

  rescue        RescueRequest @relation(fields: [rescueId], references: [id], onDelete: Cascade)

  @@unique([rescueId, userId, targetType])
  @@index([rescueId])
  @@index([targetId])
  @@map("rescue_ratings")
}

enum RescueServiceType {
  TRAFFIC_RESCUE           // "Traffic Rescue — Quick transport through traffic"
  VEHICLE_RESCUE           // "Vehicle Rescue — Get your vehicle delivered"
  PASSENGER_VEHICLE_RESCUE // "Passenger + Vehicle Rescue — We'll rescue you and move your vehicle"
  BREAKDOWN_RESCUE         // "Breakdown Rescue — Help for your vehicle"
  EMERGENCY_ASSISTANCE     // "Emergency Assistance — Accident, stranded or urgent help"
}

enum RescueStatus {
  PENDING
  DRIVER1_ACCEPTED
  BOTH_ACCEPTED
  DRIVERS_EN_ROUTE
  DRIVERS_ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model CrossZoneRule {
  id          String   @id @default(uuid())
  origin      String   // Zone code (e.g., "delhi") — resolved via geofence, falls back to city
  destination String   // Zone code (e.g., "noida")
  vehicleType String   // e.g., "auto"
  isAllowed   Boolean  @default(true)
  reason      String?  // Optional explanation of the block (e.g., "No permit to cross state border")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([origin, destination, vehicleType])
  @@index([origin, destination])
  @@map("cross_zone_rules")
}

/// Operational zone (city / state / custom service area) used for permit rules,
/// surge zones, and geofenced restrictions. Geometry is stored as an H3 cell set
/// (see ZoneCell) for fast, deterministic point-in-zone lookups without PostGIS.
model Zone {
  id        String     @id @default(uuid())
  code      String     @unique // Stable slug, e.g. "delhi", "noida", "igi_airport"
  name      String
  type      String     @default("city") // city | state | airport | custom
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  cells     ZoneCell[]

  @@index([isActive])
  @@map("zones")
}

/// A single H3 cell belonging to a zone. h3Index is unique so any location
/// deterministically resolves to at most one zone.
model ZoneCell {
  id       String @id @default(uuid())
  zoneId   String
  h3Index  String @unique // H3 index at ZONE_H3_RESOLUTION
  zone     Zone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@map("zone_cells")
}

